import { defineStore } from 'pinia'
import { ref } from 'vue'
import { supabase } from '../lib/supabase'

export const useCoursesStore = defineStore('courses', () => {
  // ─────────────────────────────────────────
  // Estado
  // ─────────────────────────────────────────

  // Lista de todos los cursos
  const courses = ref([])

  // Curso actualmente seleccionado (para editar)
  const currentCourse = ref(null)

  // Estado de carga
  const loading = ref(false)

  // Mensaje de error
  const error = ref(null)

  // ─────────────────────────────────────────
  // Acciones
  // ─────────────────────────────────────────

  // Obtiene todos los cursos (admin ve todos, incluso no publicados)
  async function fetchCourses() {
    loading.value = true
    error.value = null

    console.log('Fetching courses...')

    const { data, error: err } = await supabase
      .from('courses')
      .select('*')
      .order('created_at', { ascending: false })

    console.log('Result:', data, err)

    if (err) {
      error.value = err.message
    } else {
      courses.value = data
    }

    loading.value = false
  }

  // Obtiene un curso por su ID
  async function fetchCourseById(id) {
    loading.value = true
    error.value = null

    const { data, error: err } = await supabase
      .from('courses')
      .select(
        `
        *,
        categories (id, name)
      `,
      )
      .eq('id', id)
      .single()

    if (err) {
      error.value = err.message
    } else {
      currentCourse.value = data
    }

    loading.value = false
  }

  // Crea un nuevo curso
  async function createCourse(courseData) {
    loading.value = true
    error.value = null

    const { data, error: err } = await supabase.from('courses').insert(courseData).select().single()

    loading.value = false

    if (err) {
      error.value = err.message
      return null
    }

    // Agrega el nuevo curso al inicio de la lista
    courses.value.unshift(data)
    return data
  }

  // Actualiza un curso existente
  async function updateCourse(id, courseData) {
    loading.value = true
    error.value = null

    const { data, error: err } = await supabase
      .from('courses')
      .update(courseData)
      .eq('id', id)
      .select()
      .single()

    loading.value = false

    if (err) {
      error.value = err.message
      return null
    }

    // Actualiza el curso en la lista local
    const index = courses.value.findIndex((c) => c.id === id)
    if (index !== -1) courses.value[index] = data

    return data
  }

  // Elimina un curso
  async function deleteCourse(id) {
    loading.value = true
    error.value = null

    const { error: err } = await supabase.from('courses').delete().eq('id', id)

    loading.value = false

    if (err) {
      error.value = err.message
      return false
    }

    // Elimina el curso de la lista local
    courses.value = courses.value.filter((c) => c.id !== id)
    return true
  }

  return {
    courses,
    currentCourse,
    loading,
    error,
    fetchCourses,
    fetchCourseById,
    createCourse,
    updateCourse,
    deleteCourse,
  }
})
