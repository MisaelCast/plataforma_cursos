          type="submit"
          :disabled="saving"
          class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer"
        >
          {{ saving ? 'Guardando...' : isEditing ? 'Guardar cambios' : 'Crear curso' }}
        </button>
      </div>
    </form>
  </div>
